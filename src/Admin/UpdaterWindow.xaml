<Window x:Class="TADAdmin.UpdaterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TAD.RV — Software Update"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="760" Height="580"
        MinWidth="600" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        ResizeMode="CanResize"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom dark title bar -->
            <Border Grid.Row="0" Background="#161B22" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#58A6FF" Margin="0,0,8,0"/>
                        <TextBlock Text="Software Update" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#C9D1D9"/>
                    </StackPanel>
                    <Button x:Name="BtnTitleClose" Click="BtnLater_Click"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="32" Height="32" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                        Width="32" Height="32">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#8B949E"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#F8514944"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="28,20,28,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock x:Name="TxtHeadline" Text="A new version is available"
                               FontSize="20" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                    <TextBlock x:Name="TxtVersionLine" FontSize="12" Foreground="#8B949E"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Release notes label -->
                <TextBlock Grid.Row="1" Text="RELEASE NOTES" FontSize="10" FontWeight="SemiBold"
                           Foreground="#484F58" Margin="0,0,0,8"/>

                <!-- Release notes — FlowDocument for markdown rendering -->
                <Border Grid.Row="2" Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,0,16">
                    <FlowDocumentScrollViewer x:Name="ReleaseNotesViewer"
                                              VerticalScrollBarVisibility="Auto"
                                              IsToolBarVisible="False"
                                              Focusable="False"
                                              Background="Transparent"
                                              Foreground="#C9D1D9"
                                              FontSize="12.5"
                                              FontFamily="Segoe UI"
                                              Padding="4"/>
                </Border>

                <!-- Progress bar (hidden until download starts) -->
                <StackPanel Grid.Row="3" Margin="0,0,0,14" x:Name="ProgressPanel" Visibility="Collapsed">
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock x:Name="TxtProgressLabel" Text="Downloading…"
                                   Foreground="#8B949E" FontSize="11"/>
                        <TextBlock x:Name="TxtProgressPct" Foreground="#58A6FF" FontSize="11"
                                   DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                    </DockPanel>
                    <Border Height="4" Background="#21262D" CornerRadius="2" ClipToBounds="True">
                        <Border x:Name="PrgFill" Background="#58A6FF" CornerRadius="2"
                                HorizontalAlignment="Left" Width="0"/>
                    </Border>
                </StackPanel>

                <!-- Status line -->
                <TextBlock Grid.Row="4" x:Name="TxtStatus" Text=""
                           FontSize="11" Foreground="#8B949E" Margin="0,0,0,16"
                           TextWrapping="Wrap"/>

                <!-- Action buttons -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnLater" Content="Remind Me Later"
                            Click="BtnLater_Click" Foreground="#C9D1D9" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#21262D" BorderBrush="#30363D"
                                        BorderThickness="1" CornerRadius="6" Padding="16,8" Cursor="Hand">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#30363D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnOpenGithub" Content="View on GitHub"
                            Click="BtnOpenGithub_Click" Foreground="#58A6FF" Margin="10,0,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#21262D" BorderBrush="#30363D"
                                        BorderThickness="1" CornerRadius="6" Padding="16,8" Cursor="Hand">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#30363D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnDownload" Content="⬇  Download Update"
                            Click="BtnDownload_Click" Foreground="White" FontWeight="SemiBold"
                            Margin="10,0,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#1F6FEB" BorderBrush="#1F6FEB"
                                        BorderThickness="1" CornerRadius="6" Padding="18,8" Cursor="Hand">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#388BFD"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#30363D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
