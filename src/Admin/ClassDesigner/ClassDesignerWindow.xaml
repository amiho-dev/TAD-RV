<Window x:Class="TADAdmin.ClassDesigner.ClassDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TAD.RV — Room / Class Designer"
        WindowStyle="SingleBorderWindow"
        Background="#0D1117"
        Foreground="#C9D1D9"
        MinWidth="820" MinHeight="540"
        Width="1100" Height="700"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Seat tile button style -->
        <Style x:Key="SeatTile" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="MinHeight" Value="70"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button in toolbar -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30363D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- ── Top toolbar ── -->
        <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0">
                <!-- Room name -->
                <TextBlock Text="Room:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtRoomName" Width="140" Background="#0D1117" BorderBrush="#30363D"
                         Foreground="#C9D1D9" Padding="5,3" VerticalAlignment="Center"
                         Text="Room" Margin="0,0,12,0"/>

                <!-- Grid size -->
                <TextBlock Text="Rows:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="TxtRows" Width="40" Background="#0D1117" BorderBrush="#30363D"
                         Foreground="#C9D1D9" Padding="5,3" VerticalAlignment="Center" Text="4" Margin="0,0,8,0"
                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                <TextBlock Text="Cols:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="TxtCols" Width="40" Background="#0D1117" BorderBrush="#30363D"
                         Foreground="#C9D1D9" Padding="5,3" VerticalAlignment="Center" Text="8" Margin="0,0,8,0"
                         PreviewTextInput="NumberOnly_PreviewTextInput"/>

                <Button Content="Apply Grid" Style="{StaticResource ToolBtn}" Click="BtnApplyGrid_Click"/>

                <Separator Width="1" Background="#30363D" Margin="6,8,12,8"/>

                <Button x:Name="BtnSavePing" Content="💾 Save &amp; Ping"
                        Style="{StaticResource ToolBtn}" Click="BtnSavePing_Click"
                        Foreground="#3FB950"/>
                <Button Content="📂 Load" Style="{StaticResource ToolBtn}" Click="BtnLoad_Click"/>
                <Button Content="🗑 Clear All" Style="{StaticResource ToolBtn}" Click="BtnClearAll_Click"
                        Foreground="#F85149"/>

                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtOnlineCount" Text="— online" Foreground="#3FB950"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Seat grid (filled by code-behind) ── -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#0D1117" Padding="12">
            <UniformGrid x:Name="SeatGrid" HorizontalAlignment="Left" VerticalAlignment="Top"
                         Rows="4" Columns="8"/>
        </ScrollViewer>

        <!-- ── Seat edit panel (slides in below grid) ── -->
        <Border x:Name="EditPanel" Grid.Row="2"
                Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0"
                Visibility="Collapsed" Padding="16,10">
            <DockPanel>
                <TextBlock Text="Label:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtSeatLabel" Width="120" Background="#0D1117" BorderBrush="#30363D"
                         Foreground="#C9D1D9" Padding="5,3" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Text="Host / IP:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtSeatHost" Width="180" Background="#0D1117" BorderBrush="#30363D"
                         Foreground="#C9D1D9" Padding="5,3" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <Button Content="✔ Assign" Style="{StaticResource ToolBtn}" Click="BtnAssign_Click"
                        Foreground="#3FB950" Margin="0,0,6,0"/>
                <Button Content="✘ Clear Seat" Style="{StaticResource ToolBtn}" Click="BtnClearSeat_Click"
                        Foreground="#F85149"/>
                <Button Content="Cancel" Style="{StaticResource ToolBtn}" Click="BtnCancelEdit_Click"
                        DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- ── Status bar ── -->
        <Border Grid.Row="3" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock x:Name="TxtStatus" Text="Ready — click a seat to assign an endpoint"
                           Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
