<Window x:Class="TADAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="TAD.RV — Admin Controller"
        WindowState="Maximized"
        Background="#0D1117"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!-- Dark window chrome — eliminates the white title bar -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="4"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ═══ Compact Toolbar Button ════════════════════════════════ -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#C9D1D9" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30363D" />
                            </Trigger>
                            <!-- Tag-based accent colors -->
                            <Trigger Property="Tag" Value="danger">
                                <Setter Property="Foreground" Value="#F85149" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="danger"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#F8514918" />
                            </MultiTrigger>
                            <Trigger Property="Tag" Value="success">
                                <Setter Property="Foreground" Value="#3FB950" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="success"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#3FB95018" />
                            </MultiTrigger>
                            <Trigger Property="Tag" Value="info">
                                <Setter Property="Foreground" Value="#58A6FF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="info"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#58A6FF18" />
                            </MultiTrigger>
                            <Trigger Property="Tag" Value="warning">
                                <Setter Property="Foreground" Value="#D29922" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="warning"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#D2992218" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Caption button (min/max/close) -->
        <Style x:Key="CaptionBtn" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8B949E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ═══ Dark ComboBox ════════════════════════════════════ -->
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Border x:Name="Bd" Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1">
                        <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#8B949E"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="#161B22" BorderBrush="#30363D"
                                        BorderThickness="1" CornerRadius="4"
                                        Margin="0,2,0,0" Padding="0,4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="300">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#C9D1D9"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="Transparent"
                                            Padding="10,6" Margin="2,0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2658A6FF"/>
                                            <Setter Property="Foreground" Value="#58A6FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F85149"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />  <!-- Title bar -->
            <RowDefinition Height="40" />  <!-- Toolbar -->
            <RowDefinition Height="*" />   <!-- Content -->
            <RowDefinition Height="24" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Custom Title Bar ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#161B22">
            <DockPanel>
                <!-- App identity (left) -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left"
                            Margin="12,0,0,0" VerticalAlignment="Center">
                    <Image x:Name="TitleBarLogo" Width="18" Height="18"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="TAD.RV" FontSize="12" FontWeight="Bold"
                               Foreground="#58A6FF" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Admin Controller" FontSize="12"
                               Foreground="#484F58" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDemoTag" Text="  DEMO" FontSize="9" FontWeight="Bold"
                               Foreground="#D29922" VerticalAlignment="Center"
                               Visibility="Collapsed"
                               Padding="6,2" Margin="8,0,0,0">
                        <TextBlock.Background>
                            <SolidColorBrush Color="#D29922" Opacity="0.15"/>
                        </TextBlock.Background>
                    </TextBlock>
                </StackPanel>

                <!-- Window controls (right) -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="&#xE921;" Style="{StaticResource CaptionBtn}"
                            Click="CaptionMinimize_Click"/>
                    <Button x:Name="BtnCaptionMaxRestore" Content="&#xE922;"
                            Style="{StaticResource CaptionBtn}"
                            Click="CaptionMaxRestore_Click"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CaptionCloseBtn}"
                            Click="CaptionClose_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Toolbar ═══════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#0D1117" BorderBrush="#21262D" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button x:Name="BtnLockAll" Click="BtnLockAll_Click"
                            Style="{StaticResource ToolBtn}" Tag="danger">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Lock" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnUnlockAll" Click="BtnUnlockAll_Click"
                            Style="{StaticResource ToolBtn}" Tag="success" Margin="2,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE785;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Unlock" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="#21262D" Margin="6,8" />

                    <Button x:Name="BtnFreezeAll" Click="BtnFreezeAll_Click"
                            Style="{StaticResource ToolBtn}" Tag="warning" Margin="2,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7AD;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Freeze" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnBlankAll" Click="BtnBlankAll_Click"
                            Style="{StaticResource ToolBtn}" Tag="info" Margin="2,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7B3;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Blank" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="#21262D" Margin="6,8" />

                    <Button x:Name="BtnRefresh" Click="BtnRefresh_Click"
                            Style="{StaticResource ToolBtn}" Margin="2,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="#21262D" Margin="6,8" />

                    <Button x:Name="BtnRoomDesigner" Click="BtnRoomDesigner_Click"
                            Style="{StaticResource ToolBtn}" Tag="info" Margin="2,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Room" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="#21262D" Margin="6,8" />

                    <!-- Room filter dropdown -->
                    <TextBlock Text="Room:" Foreground="#8B949E" FontSize="12"
                               VerticalAlignment="Center" Margin="4,0,4,0"/>
                    <ComboBox x:Name="CmbRoomFilter"
                              Width="140" Height="28"
                              VerticalAlignment="Center"
                              SelectionChanged="CmbRoomFilter_SelectionChanged"
                              Style="{StaticResource DarkCombo}"
                              ToolTip="Filter students by room — 'All Rooms' shows everyone">
                        <ComboBoxItem Content="All Rooms" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>

                <!-- Right side: manual endpoint add -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBox x:Name="TxtManualIp"
                             Width="130"
                             Text="IP or hostname…"
                             VerticalAlignment="Center"
                             Padding="8,5"
                             Background="#161B22"
                             Foreground="#484F58"
                             BorderBrush="#30363D"
                             CaretBrush="#58A6FF"
                             FontSize="12"
                             ToolTip="Enter IP or hostname to connect without a DC"
                             GotFocus="TxtManualIp_GotFocus"
                             LostFocus="TxtManualIp_LostFocus"
                             KeyDown="TxtManualIp_KeyDown">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="4">
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                              Margin="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button x:Name="BtnAddEndpoint" Click="BtnAddEndpoint_Click"
                            Style="{StaticResource ToolBtn}" Tag="success" Margin="4,0,0,0"
                            ToolTip="Add endpoint manually">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Add" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ WebView2 Dashboard ════════════════════════════════════ -->
        <wv2:WebView2 x:Name="DashboardWebView" Grid.Row="2"
                      DefaultBackgroundColor="#0D1117" />

        <!-- ═══ VS Code-style Status Bar ══════════════════════════════ -->
        <Border Grid.Row="3" Background="#1F6FEB" BorderThickness="0">
            <DockPanel Margin="0,0,0,0">
                <!-- Left section -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <!-- Connection indicator -->
                    <Border Background="#1558C0" Padding="8,0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE703;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtConnected" Text="0 / 0" Foreground="White"
                                       FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Status message -->
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#FFFFFFCC"
                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Right section -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Mode badge -->
                    <TextBlock x:Name="TxtModeBadge" Text="Production" Foreground="#FFFFFFAA"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Width="1" Background="#FFFFFF33" Margin="0,5"/>
                    <!-- Version -->
                    <TextBlock x:Name="TxtVersionBar" Foreground="#FFFFFFAA"
                               FontSize="11" VerticalAlignment="Center" Margin="8,0,10,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
