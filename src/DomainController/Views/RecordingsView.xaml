<!-- RecordingsView.xaml — Automatic screenshot & recording management -->
<UserControl x:Class="TADDomainController.Views.RecordingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PrimaryBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28">
        <StackPanel MaxWidth="900">

            <TextBlock Text="Recordings" Style="{StaticResource SectionHeader}" />

            <!-- Status Banner -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <DockPanel>
                    <Ellipse Width="10" Height="10" DockPanel.Dock="Left"
                             Margin="0,0,10,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="13" VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </DockPanel>
            </Border>

            <!-- Configuration Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Configuration" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                    <!-- Screenshot Interval -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Screenshot interval (min)"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding IntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotActive}"
                                 FontSize="13" Padding="8,5"
                                 Background="#0D1117"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}" />
                    </Grid>

                    <!-- Save Folder -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Save folder"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SaveFolder, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotActive}"
                                 FontSize="12" Padding="8,5"
                                 Background="#0D1117"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}" />
                        <Button Grid.Column="2" Content="Browse…"
                                Click="BtnBrowse_Click"
                                IsEnabled="{Binding IsNotActive}"
                                Style="{StaticResource AccentButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- Video Recording Toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <CheckBox IsChecked="{Binding VideoEnabled}"
                                  IsEnabled="{Binding IsNotActive}"
                                  Content="Also record H.264 video stream  (.h264 files)"
                                  FontSize="12"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Controls Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="▶  Start Recording"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding StartCommand}" />
                        <Button Content="■  Stop"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding StopCommand}"
                                Background="{StaticResource DangerBrush}"
                                Margin="12,0,0,0" />
                        <Button Content="📁  Open Folder"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding OpenFolderCommand}"
                                Margin="12,0,0,0" />
                        <TextBlock Text="{Binding DiscoveredCount, StringFormat='{}{0} endpoint(s) connected'}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="20,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Recent Captures -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Recent Captures" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <Button Content="Clear" DockPanel.Dock="Right"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Right"
                                Command="{Binding ClearHistoryCommand}" />
                    </DockPanel>

                    <ListView ItemsSource="{Binding RecentCaptures}"
                              Background="Transparent" BorderThickness="0"
                              MaxHeight="400" SelectionMode="Single"
                              MouseDoubleClick="OnCaptureDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="80"
                                                DisplayMemberBinding="{Binding TimestampDisplay}" />
                                <GridViewColumn Header="Host" Width="140"
                                                DisplayMemberBinding="{Binding Hostname}" />
                                <GridViewColumn Header="IP" Width="120"
                                                DisplayMemberBinding="{Binding Ip}" />
                                <GridViewColumn Header="Type" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsVideo, Converter={StaticResource BoolToTypeConverter}}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Size" Width="80"
                                                DisplayMemberBinding="{Binding FileSizeDisplay}" />
                                <GridViewColumn Header="Path" Width="300"
                                                DisplayMemberBinding="{Binding FilePath}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock Text="Double-click a row to open the file."
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0" Opacity="0.6" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
