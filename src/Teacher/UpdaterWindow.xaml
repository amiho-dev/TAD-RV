<Window x:Class="TadTeacher.UpdaterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TAD.RV — Software Update"
        WindowStyle="SingleBorderWindow"
        Background="#0D1117"
        Foreground="#C9D1D9"
        Width="560" Height="420"
        MinWidth="480" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                       Foreground="#58A6FF" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TxtHeadline" Text="A new version is available"
                           FontSize="18" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                <TextBlock x:Name="TxtVersionLine"
                           FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Release notes label -->
        <TextBlock Grid.Row="1" Text="Release Notes" FontSize="12" FontWeight="SemiBold"
                   Foreground="#8B949E" Margin="0,0,0,6"/>

        <!-- Release notes box -->
        <Border Grid.Row="2" Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <TextBlock x:Name="TxtReleaseNotes" TextWrapping="Wrap"
                           Foreground="#C9D1D9" FontSize="12" FontFamily="Consolas"/>
            </ScrollViewer>
        </Border>

        <!-- Progress bar (hidden until download starts) -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14" x:Name="ProgressPanel" Visibility="Collapsed">
            <DockPanel Margin="0,0,0,4">
                <TextBlock x:Name="TxtProgressLabel" Text="Downloading..."
                           Foreground="#8B949E" FontSize="11"/>
                <TextBlock x:Name="TxtProgressPct" Foreground="#58A6FF" FontSize="11"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
            <ProgressBar x:Name="PrgDownload" Height="6" Background="#21262D"
                         Foreground="#58A6FF" BorderThickness="0" IsIndeterminate="False"
                         Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>

        <!-- Status line -->
        <TextBlock Grid.Row="4" x:Name="TxtStatus" Text=""
                   FontSize="11" Foreground="#8B949E" Margin="0,0,0,16"
                   TextWrapping="Wrap"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnLater" Content="Remind Me Later"
                    Click="BtnLater_Click"
                    Background="#21262D" BorderBrush="#30363D"
                    Foreground="#C9D1D9" Padding="14,7" Margin="0,0,10,0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="BtnOpenGithub" Content="View on GitHub"
                    Click="BtnOpenGithub_Click"
                    Background="#21262D" BorderBrush="#30363D"
                    Foreground="#58A6FF" Padding="14,7" Margin="0,0,10,0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="BtnDownload" Content="⬇ Download Update"
                    Click="BtnDownload_Click"
                    Background="#1F6FEB" BorderBrush="#1F6FEB"
                    Foreground="White" FontWeight="SemiBold" Padding="16,7"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#388BFD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
