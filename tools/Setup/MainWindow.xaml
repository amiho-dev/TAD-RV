<Window x:Class="TADSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TAD Setup"
        Height="300" Width="480"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        Foreground="#E0E0F0"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Modern rounded button style -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="106"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim browse button -->
        <Style x:Key="BrowseBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Slim path text box -->
        <Style x:Key="PathTb" TargetType="TextBox">
            <Setter Property="Background" Value="#0D0D1F"/>
            <Setter Property="Foreground" Value="#C0C0E0"/>
            <Setter Property="CaretBrush" Value="#00C8FF"/>
            <Setter Property="SelectionBrush" Value="#00C8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2C2C4C"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Modern progress bar -->
        <Style x:Key="PBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="7"/>
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3.5"/>
                            <Border x:Name="PART_Track" CornerRadius="3.5"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3.5"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76"/>    <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- path row -->
            <RowDefinition Height="*"/>     <!-- progress -->
            <RowDefinition Height="62"/>    <!-- button bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#22223A" Padding="22,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               Text="TAD Setup"
                               FontSize="21" FontWeight="Bold"
                               Foreground="#00C8FF"/>
                    <TextBlock x:Name="SubtitleText"
                               Text="v26.3.03.005  ·  TAD Europe"
                               FontSize="11" Foreground="#5A5A7A"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Status badge -->
                <Border x:Name="StatusBadge"
                        Grid.Column="1"
                        CornerRadius="4" Padding="10,4"
                        Background="#1E3A1E" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusBadgeText"
                               Text="NOT INSTALLED"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#60D060"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── Install path ───────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="22,14,22,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="36"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                       Text="Install location"
                       FontSize="11" Foreground="#5A5A7A"
                       Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="0"
                     x:Name="PathBox"
                     Style="{StaticResource PathTb}"
                     Text="C:\Program Files\TAD"/>
            <Button Grid.Row="1" Grid.Column="2"
                    x:Name="BrowseBtn"
                    Content="…"
                    Background="#2C2C4C" Foreground="#C0C0E0"
                    Style="{StaticResource BrowseBtn}"
                    Click="BrowseBtn_Click"/>
        </Grid>

        <!-- ── Progress ───────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Margin="22,18,22,0" VerticalAlignment="Top">
            <Grid Margin="0,0,0,8">
                <TextBlock x:Name="StepText"
                           Text="Ready."
                           FontSize="11" Foreground="#8888AA"/>
                <TextBlock x:Name="PctText"
                           Text=""
                           FontSize="11" Foreground="#00C8FF"
                           HorizontalAlignment="Right"/>
            </Grid>
            <ProgressBar x:Name="PBar"
                         Value="0" Minimum="0" Maximum="100"
                         Style="{StaticResource PBar}"/>
        </StackPanel>

        <!-- ── Button bar ─────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#22223A">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">
                <Button x:Name="UninstallBtn"
                        Content="Uninstall"
                        Background="#3A1818" Foreground="#FF5A5A"
                        Style="{StaticResource Btn}"
                        Margin="0,0,8,0"
                        Click="UninstallBtn_Click"/>
                <Button x:Name="InstallBtn"
                        Content="Install"
                        Background="#00C8FF" Foreground="#0A0A1A"
                        Style="{StaticResource Btn}"
                        Margin="0,0,8,0"
                        Click="InstallBtn_Click"/>
                <Button x:Name="CloseBtn"
                        Content="Close"
                        Background="#2C2C4C" Foreground="#8888AA"
                        Style="{StaticResource Btn}"
                        Click="CloseBtn_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
